{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://misra-platform.local/schemas/events/analysis-run-started.v1.json",
  "title": "AnalysisRunStarted",
  "type": "object",
  "required": ["event_id", "event_type", "occurred_at", "payload"],
  "properties": {
    "event_id": { "type": "string", "format": "uuid" },
    "event_type": { "const": "analysis.run.started" },
    "occurred_at": { "type": "string", "format": "date-time" },
    "correlation_id": { "type": "string" },
    "payload": {
      "type": "object",
      "required": ["project_id", "analysis_run_id", "run_type"],
      "properties": {
        "project_id": { "type": "string", "format": "uuid" },
        "analysis_run_id": { "type": "string", "format": "uuid" },
        "run_type": { "type": "string", "enum": ["full", "incremental"] }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
